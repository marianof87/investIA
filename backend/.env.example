# IAinvestor Backend — Environment Variables
# Copy this to .env and fill in your keys

# ── Alpaca (Real-time US Prices) ──────────────────────────────────────────────
# Get free key at: https://alpaca.markets (Paper Trading account)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://data.alpaca.markets

# ── Finnhub (Prices + News + Sentiment) ───────────────────────────────────────
# Get free key at: https://finnhub.io (60 calls/min, ~300/day)
FINNHUB_TOKEN=your_finnhub_token_here

# ── Financial Modeling Prep (Fundamentals) ────────────────────────────────────
# Get free key at: https://financialmodelingprep.com (250 calls/day)
FMP_API_KEY=your_fmp_key_here

# ── Alpha Vantage (Technical Indicators fallback) ─────────────────────────────
# Get free key at: https://alphavantage.co (25 calls/day)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# ── Twelve Data (Historical multi-asset) ──────────────────────────────────────
# Get free key at: https://twelvedata.com (800 calls/day)
TWELVE_DATA_KEY=your_twelve_data_key_here

# ── App Settings ──────────────────────────────────────────────────────────────
PRICE_CACHE_TTL=30          # seconds
FUNDAMENTAL_CACHE_TTL=86400 # 24 hours
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
